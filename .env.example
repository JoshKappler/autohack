# Required
GITHUB_TOKEN=ghp_...

# Claude backend: "cli" (default, uses Max subscription) or "api" (uses ANTHROPIC_API_KEY)
CLAUDE_BACKEND=cli

# Only needed if CLAUDE_BACKEND=api
ANTHROPIC_API_KEY=

# Optional — for authenticated Algora API endpoints
ALGORA_TOKEN=

# Discovery
TARGET_LANGUAGES=all
EXCLUDE_ORGS=
EXCLUDE_REPOS=
MAX_ISSUE_AGE_DAYS=30

# Solver
CLAUDE_MODEL=opus
SOLVE_TIMEOUT_MINUTES=30
MAX_RETRY_ATTEMPTS=2

# Control
REQUIRE_APPROVAL=true
AUTO_RESPOND_REVIEWS=false
AUTO_FIX_REVIEWS=false
MAX_REVIEW_FIX_ATTEMPTS=2
MAX_CONCURRENT_BOUNTIES=1

# Paths
WORKSPACE_DIR=.workspaces
DB_PATH=data/algora.db

# Dashboard
DASHBOARD_PORT=3456
